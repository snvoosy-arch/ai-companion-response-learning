DISCORD_TOKEN=
DISCORD_GUILD_ID=

# OpenAI-compatible local model server
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=
VLLM_MODEL=

# Legacy aliases are still accepted.
# LM_STUDIO_BASE_URL=http://127.0.0.1:8000/v1
# LM_STUDIO_API_KEY=
# LM_STUDIO_MODEL=

SYSTEM_PROMPT=Korean Discord AI companion. Reply naturally and briefly; say when you do not know.
DISABLE_THINKING=true
CHAT_REPLY_ENABLED=true
REPLY_WHEN_MENTIONED=true
DISCORD_CHAT_CHANNEL_IDS=
CHAT_HISTORY_MESSAGES=8

# Memory and runtime state
MEMORY_DB_PATH=~/.bot-runtime/white/discord_memory.sqlite3
MEMORY_RECENT_MESSAGES=16
MEMORY_SUMMARY_TRIGGER_MESSAGES=24
MEMORY_SUMMARY_BATCH_MESSAGES=20
TEMPERATURE=0.7
MAX_OUTPUT_TOKENS=512
REQUEST_TIMEOUT_SECONDS=120
WAIT_FOR_LLM_SECONDS=420
OUTPUT_GUARD_NO_CANNED_FALLBACK=true
BOT_STARTUP_LOG_PATH=~/.bot-runtime/white/startup/white_startup.log

# Optional web search
WEB_SEARCH_MODE=off
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic
TAVILY_COUNTRY=south korea
TAVILY_NEWS_TIME_RANGE=month

# Duo mode
DUO_ENABLED=false
DUO_PARTNER_BOT_ID=
DUO_CHANNEL_IDS=
DUO_MAX_REPLIES=8
DUO_REPLY_DELAY_SECONDS=1.5

# Shared bot runtime
BOT_RUNTIME_ENABLED=true
BOT_RUNTIME_STATE_DB_PATH=${USERPROFILE}/.bot-runtime/shared/runtime/bot_runtime_state.sqlite3
BOT_RUNTIME_BOT_NAME=white
BOT_RUNTIME_HEARTBEAT_SECONDS=15
BOT_RUNTIME_ONLINE_TIMEOUT_SECONDS=45
BOT_RUNTIME_AUTO_CLAIM_TTL_SECONDS=300
BOT_RUNTIME_MANUAL_CLAIM_TTL_SECONDS=1800
BOT_STARTUP_SINGLETON_ENABLED=true
BOT_STARTUP_SINGLETON_LOCK_PATH=~/.bot-runtime/white/white_startup.lock

# Shared speech runtime / TTS
TTS_ENABLED=false
TTS_MODE=off
TTS_PROVIDER=noop
TTS_COMMAND_TEMPLATE=
TTS_PLAY_COMMAND_TEMPLATE=
TTS_XTTS_SERVER_URL=
TTS_XTTS_SERVER_TOKEN=
TTS_XTTS_CLIENT_PYTHON=
TTS_XTTS_CLIENT_SCRIPT=
TTS_XTTS_LANGUAGE=ko
TTS_GPTSOVITS_SERVER_URL=
TTS_GPTSOVITS_SERVER_TOKEN=
TTS_GPTSOVITS_CLIENT_PYTHON=
TTS_GPTSOVITS_CLIENT_SCRIPT=
TTS_GPTSOVITS_SPEAKER_MANIFEST=
TTS_GPTSOVITS_LANGUAGE=ko
GPTSOVITS_SYNTH_COMMAND_TEMPLATE=
TTS_LOCAL_PLAYER=auto
TTS_FFMPEG_EXECUTABLE=ffmpeg
TTS_OUTPUT_DIR=~/.bot-runtime/white/tts
TTS_OBS_OUTPUT_DIR=~/.bot-runtime/white/obs-live
TTS_AUDIO_FORMAT=ogg
TTS_MAX_CHARS=240

# Optional ElevenLabs provider
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_REQUEST_TIMEOUT_SECONDS=60

TTS_WHITE_VOICE_ID=white_default
TTS_BLACK_VOICE_ID=black_default
TTS_WHITE_SPEED=0.94
TTS_BLACK_SPEED=1.02
TTS_WHITE_STYLE=soft
TTS_BLACK_STYLE=clear

