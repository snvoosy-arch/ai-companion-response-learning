DISCORD_BOT_TOKEN=
BOT_TRIGGER_PREFIX=
DEFAULT_LOCATION=
BOT_PERSONA=black

# Generation backend: template / kobart / openai
GENERATION_BACKEND=kobart
STRICT_LLM_ONLY=true
KOBART_MODEL_NAME_OR_PATH=gogamza/kobart-base-v2
KOBART_INPUT_MODE=full
KOBART_DEVICE=auto
KOBART_MAX_NEW_TOKENS=64
KOBART_NUM_BEAMS=4

# State storage
STATE_BACKEND=sqlite
STATE_DB_PATH=
STATE_MAX_RECENT_TURNS=6

# Optional intent classifier settings
INTENT_MODEL_TYPE=kcbert
KCBERT_MODEL_PATH=
KCBERT_DEVICE=auto
INTENT_MODEL_PATH=
INTENT_MODEL_MIN_CONFIDENCE=0.10
POLICY_ACTION_MODEL_PATH=
KNOWLEDGE_BACKEND=wikidata
WIKIDATA_USER_AGENT=predictive-discord-bot/0.1 (https://example.invalid/predictive-discord-bot)
WIKIDATA_TIMEOUT_SECONDS=10

# Optional OpenAI-compatible generation settings
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=20
LOG_MESSAGE_CONTENT=false

# Shared bot runtime
BOT_RUNTIME_ENABLED=true
BOT_RUNTIME_STATE_DB_PATH=${USERPROFILE}/.bot-runtime/shared/runtime/bot_runtime_state.sqlite3
BOT_RUNTIME_BOT_NAME=black
BOT_RUNTIME_HEARTBEAT_SECONDS=15
BOT_RUNTIME_ONLINE_TIMEOUT_SECONDS=45
BOT_RUNTIME_AUTO_CLAIM_TTL_SECONDS=300
BOT_RUNTIME_MANUAL_CLAIM_TTL_SECONDS=1800
BOT_STARTUP_LOCK_ENABLED=true
BOT_STARTUP_LOCK_PATH=

# Bot-vs-bot duo test mode
BOT_DUO_ENABLED=false
BOT_DUO_PARTNER_BOT_ID=
BOT_DUO_CHANNEL_ID=
BOT_DUO_MAX_TURNS_PER_BOT=6
BOT_DUO_AUTOSTART_ENABLED=false
BOT_DUO_AUTOSTART_CHANNEL_ID=
BOT_DUO_AUTOSTART_PROMPT=

# Shared speech runtime / TTS
TTS_ENABLED=false
TTS_MODE=off
TTS_PROVIDER=noop
TTS_COMMAND_TEMPLATE=
TTS_PLAY_COMMAND_TEMPLATE=
TTS_XTTS_SERVER_URL=
TTS_XTTS_SERVER_TOKEN=
TTS_XTTS_CLIENT_PYTHON=
TTS_XTTS_CLIENT_SCRIPT=
TTS_XTTS_LANGUAGE=ko
TTS_GPTSOVITS_SERVER_URL=
TTS_GPTSOVITS_SERVER_TOKEN=
TTS_GPTSOVITS_CLIENT_PYTHON=
TTS_GPTSOVITS_CLIENT_SCRIPT=
TTS_GPTSOVITS_SPEAKER_MANIFEST=
TTS_GPTSOVITS_LANGUAGE=ko
GPTSOVITS_SYNTH_COMMAND_TEMPLATE=
TTS_LOCAL_PLAYER=auto
TTS_FFMPEG_EXECUTABLE=ffmpeg
TTS_OUTPUT_DIR=~/.bot-runtime/black/tts
TTS_OBS_OUTPUT_DIR=~/.bot-runtime/black/obs-live
TTS_AUDIO_FORMAT=ogg
TTS_MAX_CHARS=240

# Optional ElevenLabs provider
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_REQUEST_TIMEOUT_SECONDS=60

TTS_WHITE_VOICE_ID=white_default
TTS_BLACK_VOICE_ID=black_default
TTS_WHITE_SPEED=0.94
TTS_BLACK_SPEED=1.02
TTS_WHITE_STYLE=soft
TTS_BLACK_STYLE=clear

